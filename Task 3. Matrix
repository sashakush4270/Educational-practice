#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<vector<int>> a(n, vector<int>(n));

    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            cin >> a[i][j];

    int max_val = a[0][0];
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            if (a[i][j] > max_val)
                max_val = a[i][j];

    int count_even = 0;
    int count_sector1 = 0;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i + j < n - 1) {
                if (a[i][j] % 2 == 0)
                    count_even++;
            }

            if (i == j || i + j == n - 1) {
                count_sector1++;
                a[i][j] = max_val;
            }
        }
    }

    cout << count_even << endl;
    cout << count_sector1 << endl;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++)
            cout << a[i][j] << " ";
        cout << endl;
    }

    return 0;
}
